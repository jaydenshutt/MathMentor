<UserControl x:Class="MathMentor.Views.QuizResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MathMentor.Converters">
    <UserControl.Resources>
        <conv:CorrectToBrushConverter x:Key="CorrectBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
        <StackPanel MaxWidth="800" HorizontalAlignment="Center">
            <TextBlock Text="Practice complete" Style="{StaticResource PageTitle}"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Headline}" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding ScoreLabel}" FontSize="48" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="New personal best!" Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               Visibility="{Binding IsNewBest, Converter={StaticResource BoolVis}}"/>
                    <TextBlock Text="{Binding Recommendation}" Style="{StaticResource BodyText}"
                               TextAlignment="Center" Margin="0,16,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="Retake quiz" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Command="{Binding RetakeCommand}"/>
                        <Button Content="Review lesson" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Command="{Binding ReviewLessonCommand}"/>
                        <Button Content="Next lesson" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Command="{Binding NextLessonCommand}"/>
                        <Button Content="Dashboard" Style="{StaticResource SecondaryButton}" Command="{Binding DashboardCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Breakdown" Style="{StaticResource SectionHeading}"/>
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="14">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Status}" FontWeight="Bold"
                                               Foreground="{Binding IsCorrect, Converter={StaticResource CorrectBrush}}"/>
                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Run Text="Q"/><Run Text="{Binding Number, Mode=OneWay}"/>
                                        <Run Text=", "/>
                                        <Run Text="{Binding Prompt, Mode=OneWay}"/>
                                    </TextBlock>
                                </DockPanel>
                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="Your answer: "/><Run Text="{Binding UserAnswer, Mode=OneWay}"/>
                                    <Run Text="  ·  Correct: "/><Run Text="{Binding CorrectAnswer, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Explanation}" Style="{StaticResource BodyText}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
