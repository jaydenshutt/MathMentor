<UserControl x:Class="MathMentor.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MathMentor.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
        <StackPanel MaxWidth="640">
            <TextBlock Text="About MathMentor" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Who built this free learning app, and how to get in touch."
                       Style="{StaticResource PageSubtitle}"/>

            <!-- Creator credit (primary focus) -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Creator" FontWeight="Bold" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding CreatorCredit}"
                               Margin="0,0,0,6" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding AppDescription}" Style="{StaticResource BodyText}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding ConnectInvitation}" Style="{StaticResource BodyText}"
                               FontStyle="Italic" Margin="0,0,0,18"
                               LineHeight="22"/>

                    <TextBlock Text="Connect on LinkedIn" FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left"
                            Padding="16,10"
                            Command="{Binding OpenLinkedInCommand}"
                            ToolTip="{Binding LinkedInUrl}">
                        <TextBlock>
                            <Run Text="Open profile: "/><Run Text="{Binding LinkedInDisplay, Mode=OneWay}"/>
                        </TextBlock>
                    </Button>
                    <TextBlock Margin="0,10,0,0" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap">
                        <Hyperlink NavigateUri="{Binding LinkedInUrl}"
                                   RequestNavigate="LinkedIn_RequestNavigate"
                                   Foreground="{DynamicResource Accent2Brush}">
                            <Run Text="{Binding LinkedInUrl, Mode=OneWay}"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Optional support (secondary, quieter) -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Opacity="0.92">
                <StackPanel>
                    <TextBlock Text="A note of gratitude" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding SupportMessage}" Style="{StaticResource BodyText}"
                               Margin="0,8,0,12" FontSize="13"/>

                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="10" Padding="14" HorizontalAlignment="Left"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Visibility="{Binding PayPalQrImage, Converter={StaticResource NullVis}}">
                        <StackPanel>
                            <TextBlock Text="Scan with your phone or PayPal app"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <Border Background="White" CornerRadius="6" Padding="8" HorizontalAlignment="Center">
                                <Image Source="{Binding PayPalQrImage}"
                                       Width="140" Height="140"
                                       Stretch="Uniform"
                                       SnapsToDevicePixels="True"/>
                            </Border>
                            <TextBlock Text="Optional, via PayPal"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Open PayPal in browser"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0"
                            Padding="12,8"
                            Command="{Binding OpenPayPalCommand}"
                            Visibility="{Binding HasPayPalUrl, Converter={StaticResource BoolVis}}"/>
                </StackPanel>
            </Border>

            <Button Content="← Back to Dashboard" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Left" Command="{Binding BackToDashboardCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
