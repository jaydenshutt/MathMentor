<UserControl x:Class="MathMentor.Views.ReviewQueueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MathMentor.Converters">
    <UserControl.Resources>
        <conv:StarsConverter x:Key="Stars"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
        <StackPanel MaxWidth="900">
            <TextBlock Text="Needs Review" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Spaced-review suggestions based on last successful practice and score."
                       Style="{StaticResource PageSubtitle}"/>

            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Review" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Padding="12,8"
                                            Command="{Binding DataContext.OpenLessonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding LessonId}"/>
                                    <Button Content="Practice" Style="{StaticResource PrimaryButton}" Padding="12,8"
                                            Command="{Binding DataContext.PracticeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding LessonId}"/>
                                </StackPanel>
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding Stars, Converter={StaticResource Stars}}"
                                                   Foreground="{DynamicResource WarningBrush}" DockPanel.Dock="Right"/>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource BodyText}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Nothing queued yet. Complete a few lessons and practice sets, review suggestions will appear here."
                       Style="{StaticResource BodyText}" Margin="0,12,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
