<UserControl x:Class="MathMentor.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MathMentor.Converters">
    <UserControl.Resources>
        <conv:StarsConverter x:Key="Stars"/>
        <conv:PercentToWidthConverter x:Key="PctWidth"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
        <StackPanel MaxWidth="1100" HorizontalAlignment="Left">
            <TextBlock Text="Dashboard" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Your personalized path through arithmetic to calculus." Style="{StaticResource PageSubtitle}"/>

            <!-- Hero stats -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}"
                        Background="{DynamicResource SurfaceBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Continue learning" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ContinueTitle}" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="20" FontWeight="Bold" Margin="0,6,0,4" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ContinueSubtitle}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,14"/>
                            <Button Content="Resume lesson" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ContinueLearningCommand}" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                            <TextBlock Text="{Binding MasteryLabel}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding CompletedCount, StringFormat={}{0} completed}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Lessons started" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,8,0,0">
                            <Run Text="{Binding LessonsStarted, Mode=OneWay}"/>
                            <Run Text="/" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Run Text="{Binding TotalLessons, Mode=OneWay}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Mastery" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding OverallMastery, StringFormat={}{0:0}%}"
                                   Foreground="{DynamicResource Accent2Brush}" FontSize="28" FontWeight="Bold" Margin="0,8,0,0"/>
                        <Button Content="Review queue" Style="{StaticResource SecondaryButton}" Margin="0,12,0,0"
                                Command="{Binding OpenReviewCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Category progress" Style="{StaticResource SectionHeading}"/>
            <ItemsControl ItemsSource="{Binding Categories}" Margin="0,0,0,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,12,12" Cursor="Hand"
                                MouseLeftButtonUp="Category_Click" Tag="{Binding Id}">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource BodyText}" Margin="0,6,0,10" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                <Grid>
                                    <Border Height="8" CornerRadius="4" Background="{DynamicResource SurfaceAltBrush}"/>
                                    <Border Height="8" CornerRadius="4" Background="{DynamicResource AccentBrush}"
                                            HorizontalAlignment="Left"
                                            Width="{Binding Mastery, Converter={StaticResource PctWidth}, ConverterParameter=200}"/>
                                </Grid>
                                <DockPanel Margin="0,8,0,0">
                                    <TextBlock Text="{Binding MasteryLabel}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ProgressLabel}" Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Focus areas" Style="{StaticResource SectionHeading}" DockPanel.Dock="Left"/>
                        <Button Content="Browse all" Style="{StaticResource SecondaryButton}" DockPanel.Dock="Right"
                                HorizontalAlignment="Right" Padding="10,6" Command="{Binding BrowseAllCommand}"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding WeakAreas}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="14" Cursor="Hand"
                                        MouseLeftButtonUp="Lesson_Click" Tag="{Binding LessonId}">
                                    <DockPanel>
                                        <TextBlock Text="{Binding Stars, Converter={StaticResource Stars}}"
                                                   Foreground="{DynamicResource WarningBrush}" DockPanel.Dock="Right" Margin="12,0,0,0"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Recent activity" Style="{StaticResource SectionHeading}"/>
                    <ItemsControl ItemsSource="{Binding RecentActivity}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding When}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0" Opacity="0.8"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
