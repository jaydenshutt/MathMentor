<UserControl x:Class="MathMentor.Controls.FormulaBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinHeight="0">
    <Border x:Name="Chrome"
            Background="{DynamicResource FormulaBgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,14"
            Margin="0,8,0,6"
            SnapsToDevicePixels="True">
        <Grid MinHeight="28">
            <!-- Rendered math as a crisp bitmap (theme-colored, never empty) -->
            <Image x:Name="FormulaImage"
                   Stretch="None"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   SnapsToDevicePixels="True"
                   UseLayoutRounding="True"/>

            <!-- Plain-text fallback only if rendering truly fails -->
            <TextBlock x:Name="Fallback"
                       Visibility="Collapsed"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontFamily="Cambria Math, Segoe UI Symbol, Segoe UI"
                       FontSize="18"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
