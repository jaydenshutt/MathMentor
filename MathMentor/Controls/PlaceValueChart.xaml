<UserControl x:Class="MathMentor.Controls.PlaceValueChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Background="{DynamicResource FormulaBgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="16,14"
            Margin="0,12,0,4">
        <StackPanel>
            <DockPanel Margin="0,0,0,12">
                <TextBlock Text="Place-value chart"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="ExampleCaption"
                           DockPanel.Dock="Right"
                           HorizontalAlignment="Right"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Place headers + digit cells -->
            <ItemsControl x:Name="Columns">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3,0"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8,10"
                                MinWidth="72">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding PlaceName}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="90"/>
                                <TextBlock Text="{Binding PowerLabel}"
                                           Foreground="{DynamicResource Accent2Brush}"
                                           FontSize="10"
                                           TextAlignment="Center"
                                           Margin="0,2,0,8"
                                           Opacity="0.9"/>
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1.5"
                                        CornerRadius="6"
                                        Padding="6,8"
                                        MinWidth="40"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Digit}"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextAlignment="Center"
                                               FontFamily="Segoe UI"/>
                                </Border>
                                <TextBlock Text="{Binding ValueLabel}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Background="{DynamicResource SurfaceAltBrush}"
                    CornerRadius="8"
                    Padding="12,10"
                    Margin="0,14,0,0">
                <TextBlock x:Name="ExpandedForm"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
