<Window x:Class="MathMentor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MathMentor - Interactive Math Tutor"
        Icon="pack://application:,,,/Assets/MathMentor.ico"
        Height="820" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        FontSize="14"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Side navigation -->
        <Border Grid.Column="0" Background="{DynamicResource NavBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,12">
                    <TextBlock Text="MathMentor" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="Learn · Practice · Master" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,16">
                    <TextBlock Text="Created by Jayden Shutt"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="10" Margin="14,0,14,8" TextWrapping="Wrap"/>
                    <Button Content="About &amp; support" Style="{StaticResource NavButton}"
                            Command="{Binding GoAboutCommand}"/>
                    <Button Content="◐ Toggle theme" Style="{StaticResource NavButton}"
                            Command="{Binding ToggleThemeCommand}"/>
                </StackPanel>

                <StackPanel Margin="0,8,0,0">
                    <Button Content="Dashboard" Style="{StaticResource NavButton}"
                            Command="{Binding GoDashboardCommand}"/>
                    <Button Content="Curriculum" Style="{StaticResource NavButton}"
                            Command="{Binding GoCurriculumCommand}"/>
                    <Button Content="Needs Review" Style="{StaticResource NavButton}"
                            Command="{Binding GoReviewCommand}"/>
                    <Button Content="Settings" Style="{StaticResource NavButton}"
                            Command="{Binding GoSettingsCommand}"/>
                    <Button Content="About" Style="{StaticResource NavButton}"
                            Command="{Binding GoAboutCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Border Grid.Column="1" Background="{DynamicResource BgBrush}">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </Grid>
</Window>
